    "react"
  ],
  "framework": "react",
  "entry": "skiper24.tsx",
  "export": "TikTikColorList",
  "type": "component",
  "dependencies": {
    "react": ">=18",
    "framer-motion": ">=11",
    "gsap": ">=3.12",
    "use-sound": ">=4",
    "clsx": ">=2",
    "tailwind-merge": ">=2"
  },
  "demo": "README.md",
  "version": "1.0.0",
  "tech": [
    "React",
    "GSAP ScrollTrigger",
    "Framer Motion",
    "use-sound",
    "Tailwind"
  ],
  "api": {
    "props": {
      "projects": "Project[] (id,name,description,badge,bgColor,image) — 필수",
      "showPreview": "boolean=true — 우하단 드래그 프리뷰 카드",
      "previewSize": "'sm'|'md'|'lg'=lg",
      "enableSound": "boolean=true — 항목 전환 tick",
      "soundSrc": "string='/sfx/tick.wav'",
      "infiniteScroll": "boolean=true — 10세트 반복 + 바닥 근처 5세트 추가",
      "scrollThreshold": "number=1000 — 추가 로드 임계 px"
    }
  }
